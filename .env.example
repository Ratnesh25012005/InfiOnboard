# InfiOnboard — Environment Configuration
# Copy this file to .env and fill in values as needed.

# ── Database ──────────────────────────────────────────────────────
# Path to the SQLite catalog database file
DB_PATH=catalog.db

# ── Server ────────────────────────────────────────────────────────
# Host and port for the uvicorn server
HOST=0.0.0.0
PORT=8000

# ── Optional: Gemini AI Integration ──────────────────────────────
# If provided, the engine can use Gemini for enhanced skill parsing.
# Leave empty to use the built-in regex-based NLP engine (default).
GEMINI_API_KEY=

# ── Optional: Twilio SMS Notifications ───────────────────────────
# If provided, users can receive their pathway summary via SMS.
# Leave empty to disable SMS features.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
